{
  "name": "codex-session-guard",
  "version": "0.1.0",
  "private": true,
  "author": "Vaduvanathan P",
  "description": "Managex is a local workspace observability and cleanup app for Codex coding workspaces.",
  "type": "module",
  "main": "src/electron/main.mjs",
  "scripts": {
    "test": "node --test",
    "test:electron-bridge": "electron scripts/verify-preload-bridge.cjs",
    "scan:demo": "node scripts/scan-demo.mjs",
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist:dir": "electron-builder --dir",
    "dist:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.vaduvanathan.codexsessionguard",
    "productName": "Managex",
    "artifactName": "${productName}-${version}-setup.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!test/**/*",
      "!docs/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false
    }
  }
}
